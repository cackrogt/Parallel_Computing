(async function () {

    const urls = [
        "https://example.com",
        "https://google.com",
        "https://wikipedia.org"
    ];

    const waitTime = 15000;

    // DevTools internal API
    const target = SDK.targetManager.mainTarget();

    for (let i = 0; i < urls.length; i++) {

        const url = urls[i];

        console.log("Opening:", url);

        // Navigate using DevTools protocol
        await target.pageAgent().navigate(url);

        // Wait for page load
        await new Promise(resolve => {
            target.model(SDK.ResourceTreeModel)
                .addEventListener(
                    SDK.ResourceTreeModel.Events.Load,
                    resolve,
                    { once: true }
                );
        });

        console.log("Loaded:", url);

        // Wait extra 15 sec
        await new Promise(r => setTimeout(r, waitTime));

        console.log("Capturing screenshot...");

        // Capture screenshot
        const result =
            await target.pageAgent().captureScreenshot({
                format: "png",
                fromSurface: true,
                captureBeyondViewport: true
            });

        // Download
        const a = document.createElement("a");

        a.href =
            "data:image/png;base64," +
            result.data;

        a.download =
            `${i + 1}_` +
            url.replace(/https?:\/\//, "")
               .replace(/[^\w]/g, "_") +
            ".png";

        a.click();

        console.log("Saved screenshot");

        // Small pause
        await new Promise(r => setTimeout(r, 3000));
    }

    console.log("DONE");

})();
