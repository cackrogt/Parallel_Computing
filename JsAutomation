window.urls = [
  "https://example.com",
  "https://google.com",
  "https://wikipedia.org"
];

window.currentIndex = 0;

async function runSites() {

    while (window.currentIndex < window.urls.length) {

        const url = window.urls[window.currentIndex];

        console.log("Opening", url);

        location.href = url;

        await new Promise(resolve => {
            window.addEventListener(
                "load",
                () => resolve(),
                { once: true }
            );
        });

        await new Promise(r => setTimeout(r, 15000));

        alert(
            "Take screenshot now.\n\n" +
            "Press:\n" +
            "Ctrl+Shift+P\n" +
            "Type: screenshot\n" +
            "Enter\n\n" +
            "Then click OK for next site."
        );

        window.currentIndex++;
    }

    alert("Done");
}

runSites();


(async () => {

    // ===== CONFIG =====
    const URLS = [
        "https://example.com",
        "https://google.com",
        "https://wikipedia.org"
    ];

    const WAIT_TIME = 15000;
    // ==================

    // Persist state across navigations
    if (!localStorage.siteRunnerState) {

        localStorage.siteRunnerState = JSON.stringify({
            index: 0,
            urls: URLS
        });

        console.log("State initialized");
    }

    const state = JSON.parse(localStorage.siteRunnerState);

    // Finished?
    if (state.index >= state.urls.length) {

        console.log("ALL DONE");
        localStorage.removeItem("siteRunnerState");
        return;
    }

    const currentUrl = state.urls[state.index];

    // If not already on target URL -> navigate
    if (location.href !== currentUrl) {

        console.log("Navigating to:", currentUrl);

        location.href = currentUrl;
        return;
    }

    // Already on correct page
    console.log("Loaded:", currentUrl);

    setTimeout(() => {

        alert(
            `Take screenshot now for:\n\n${currentUrl}\n\n` +
            `Press Ctrl+Shift+P\n` +
            `Type: screenshot`
        );

        state.index++;

        localStorage.siteRunnerState =
            JSON.stringify(state);

        // Move next
        if (state.index < state.urls.length) {

            location.href = state.urls[state.index];

        } else {

            alert("ALL SITES DONE");
            localStorage.removeItem("siteRunnerState");
        }

    }, WAIT_TIME);

})();
