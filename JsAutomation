const urls = [
    "https://example.com",
    "https://google.com",
    "https://wikipedia.org"
];

const WAIT_TIME = 15000;

(async () => {

    for (let i = 0; i < urls.length; i++) {

        const url = urls[i];

        console.log("Opening:", url);

        // Navigate
        location.href = url;

        // Wait for full load
        await new Promise(resolve => {
            window.addEventListener(
                "load",
                () => resolve(),
                { once: true }
            );
        });

        console.log("Waiting 15 seconds...");

        await new Promise(r =>
            setTimeout(r, WAIT_TIME)
        );

        // Built-in DevTools screenshot command
        console.log("Take screenshot now");

        // Trigger command menu automatically
        const event = new KeyboardEvent('keydown', {
            key: 'P',
            code: 'KeyP',
            ctrlKey: true,
            shiftKey: true,
            bubbles: true
        });

        document.dispatchEvent(event);

        alert(
            "Type: screenshot\n" +
            "Press Enter"
        );

        // small delay
        await new Promise(r =>
            setTimeout(r, 3000)
        );
    }

    alert("DONE");

})();
